AUTH_SECRET=replace-with-a-long-random-secret
# NEXTAUTH_SECRET is also accepted as a legacy alias, but AUTH_SECRET is preferred.
DEMO_OPERATOR_EMAIL=operator@nexcore.local
DEMO_OPERATOR_PASSWORD=mission-control

# Future Supabase server-only adapter values. Do not expose service-role keys with NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# LINE Messaging API notification delivery. LINE_CHANNEL_ACCESS_TOKEN/LINE_GROUP_ID are preferred;
# LINE_TOKEN/GROUP_ID are accepted for legacy compatibility and system_settings fallback.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_GROUP_ID=
LINE_REQUEST_TIMEOUT_MS=10000
LINE_MAX_RETRIES=3

# SMTP fallback used when LINE delivery fails.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_TO=
